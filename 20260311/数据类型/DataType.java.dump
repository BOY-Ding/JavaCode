/*
	* 基本类型8中，整数类型4种，小数类型2中，另外还有char和boolean
	* byte 1字节 = 8bit = 1b
	* short 2字节
	* int 4字节 默认类型
	* long 8字节 写long类型需要再后面加L：long x = 10L;
	* float 单精度 声明float类型： float x = 1.2F;
	* double 双精度 默认类型
	* char 字符 2字节 只能存一个字符
	* boolean 1字节 
	*
	*
	*
*/


// double精度问题： 0.1转化成二进制是一个无限循环的 0.1*2 = 0.2;0.2*2=0.4....


// 字符类型char
class CharType {
	public static void main (String[] args) {
		// 字符只能用单引号,字符串才可以使用双引号
		// char a1 = "\t"; //错误:
		// System.out.println(a1);

		//允许使用转义字符
		char a2 = '\t'; //直接输出制表符
		System.out.println(a2);

		char a3 = '9'; //输出9
		System.out.println(a3);

		//char本质就是一个整数，只不过在输出的时候显示的是unicode对应的字符
		//char可以进行运算，运算时强制提升成int类型；

		char a4 = 97; //输出a,
		System.out.println(a4);
	}
}

//boolean
class BooleanType {
	public static void main (String[] args) {
		boolean isPass = true;
		if (isPass == true) {
			System.out.println("通过");
		} else {
			System.out.println("不通过");
		}
	}
}

//基本数据类型转换：低范围自动转换成高范围的
//(不是按字节大小，但是long转float可能会丢失精度)
// char（1byte）——> int（4byte）——> long（8byte）
// ——> float（4byte）——> double（8byte）

// byte ——> short ——> int ——> long ——> float ——> double
// 

class AutoConvert {
	 public static void main (String[] args) {
	 	//运算时会把所有的数据转换成容量最大的数据的类型
	 	// float a = 10 + 1.1; //错误，因为1.1默认是double类型
	 	float a = 1.1F; //把1.1的类型从double改成float
	 	System.out.println(a);

	 	//常量赋值时，如果数据是int类型，而声明的是byte或者short
	 	//此时会优先判断该常量是否在byte/short的范围内，如果是则可以赋值
	 	// byte b = 128; //错误: 不兼容的类型: 从int转换到byte可能会有损失
	 	byte b = 1;
	 	int c = 2;
	 	// byte d = c; //报错，此时c已经是4个字节存在内存中了,变量赋值需要判断类型

	 	//char不能和byte/short相互转换

	 	char n1 = 'a';
	 	// byte n2 = (int)n1; //错误


	 	// byte,short,char三者在运算时自动转换成int
	 	byte n2 = 100;
	 	byte n3 = 28;
	 	// byte n4 = n2 + n3; //错误int类型不能转换成byte

	 	//自动提示原则：表达式结果自动提升成操作中最大的类型
	 }
}

class forceConvert {
	public static void main (String[] args) {
		// 强制类型转换：适用强制转换符（）
		char a = 'a';
		int b = (int)a;
		System.out.println(b);
	}
}
